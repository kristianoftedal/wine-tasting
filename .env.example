# Supabase Configuration
# Public (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (server-side only, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration (for embeddings and AI features)
OPENAI_API_KEY=your-openai-api-key

# Optional: override the active weight profile (inverted | moderate)
# NEXT_PUBLIC_WEIGHT_PROFILE=inverted
